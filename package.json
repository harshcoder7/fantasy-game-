{
  "name": "fantasy-realm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Everdawn Vale — a 3D fantasy life-simulation with generative agents",
  "scripts": {
    "dev": "concurrently -k \"npm:server\" \"vite\"",
    "server": "node --env-file-if-exists=.env server/server.js",
    "build": "tsc --noEmit && vite build",
    "start": "node --env-file-if-exists=.env server/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/three": "^0.170.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
